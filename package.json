{
	"name": "@os-eco/burrow-cli",
	"version": "0.3.15",
	"description": "OS-isolated sandbox runtime for coding agents",
	"type": "module",
	"bin": {
		"burrow": "./src/cli/main.ts",
		"bw": "./src/cli/main.ts"
	},
	"main": "src/index.ts",
	"files": ["src"],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"keywords": ["ai", "agents", "sandbox", "bwrap", "sandbox-exec", "cli", "developer-tools"],
	"author": "Jaymin West",
	"license": "MIT",
	"homepage": "https://github.com/jayminwest/burrow",
	"bugs": {
		"url": "https://github.com/jayminwest/burrow/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jayminwest/burrow.git"
	},
	"scripts": {
		"test": "bun test",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"check:agents": "bun run scripts/validate-agents-md.ts",
		"check:dups": "bunx jscpd",
		"check:deps": "knip --dependencies",
		"check:size": "bun run scripts/check-file-sizes.ts --budget scripts/file-size-budgets.json",
		"check:debt": "bun run scripts/check-debt-markers.ts --budget scripts/debt-markers-budget.json",
		"check:coverage": "bun run scripts/check-coverage.ts --budget scripts/coverage-budgets.json",
		"check:ci-parity": "bun scripts/check-ci-parity.ts",
		"check:all": "bun scripts/check-all.ts",
		"verify": "bun run check:all",
		"version:bump": "bun run scripts/version-bump.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "latest",
		"drizzle-kit": "^0.31.10",
		"knip": "^6.16.1",
		"typescript": "^6.0.3",
		"yaml": "^2.9.0"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^15.0.0",
		"drizzle-orm": "^0.45.2",
		"p-queue": "^9.2.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"smol-toml": "^1.6.1",
		"zod": "^4.4.3"
	}
}
