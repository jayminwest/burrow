{
	"$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/packages/jscpd/schemas/jscpd.json",
	"pattern": "src/**/*.{ts,tsx}",
	"ignore": [
		"**/node_modules/**",
		"**/__golden__/**",
		"**/*.test.ts",
		"**/*.test.tsx",
		"test/**",
		"tests/**",
		"dist/**",
		"coverage/**"
	],
	"languages": ["typescript"],
	"format": ["typescript"],
	"minTokens": 100,
	"threshold": 3,
	"reporters": ["consoleFull"],
	"absolute": false,
	"gitignore": true,
	"silent": false
}
