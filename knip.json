{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignore": [
		".bun/**",
		"data/**",
		"dist/**",
		"coverage/**",
		"test-results/**"
	],
	"workspaces": {
		".": {
			"entry": [
				"scripts/**/*.ts",
				"**/*.test.ts"
			],
			"project": [
				"src/**/*.ts",
				"scripts/**/*.ts"
			]
		}
	},
	"ignoreDependencies": [
		"pino-pretty"
	]
}
