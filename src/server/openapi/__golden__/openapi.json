    "/burrows/{id}/events": {
      "get": {
        "operationId": "eventsTail",
        "summary": "Tail per-burrow events as NDJSON over chunked HTTP. Wire bytes match `burrow events --json` exactly.",
        "tags": [
          "events",
          "streams"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^bur_"
            },
            "required": true,
            "description": "Burrow id, e.g. `bur_a3f9`."
          },
          {
            "name": "follow",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false",
                "1",
                "0"
              ]
            },
            "description": "When true (default), keep the connection open and live-tail; when false, drain current rows and close. Accepts `true`/`false` or `1`/`0`."
          },
          {
            "name": "since",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0
            },
            "description": "Emit only events with `seq > since`. Non-negative integer."
          },
          {
            "name": "kinds",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of event kinds to include. Repeated `?kinds=` parameters merge."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Maximum rows to return; positive integer."
          },
          {
            "name": "pollIntervalMs",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0
            },
            "description": "Override the live-tail poll interval (ms)."
          }
        ],
        "responses": {
          "200": {
            "description": "Newline-delimited `EventEnvelope` records (one per line).",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "$ref": "#/components/schemas/EventEnvelope"
                }
              }
            }
          },
          "400": {
            "description": "Error envelope (`validation_error`).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Error envelope (`not_found`).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
